# Copy to .env and fill in real values. .env is gitignored.

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key — used by every specialist + the report writer.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# GitHub personal access token — used by the GitHub API client (rate-limited
# 5000/h authenticated vs 60/h unauthenticated, and many endpoints we hit
# require auth at all).
#
# Scopes:
#   - public_repo            (analyzing public repos — most common case)
#   - repo                   (only if you'll point this at private repos)
# Generate at https://github.com/settings/tokens (classic) or
# https://github.com/settings/personal-access-tokens (fine-grained).
GITHUB_TOKEN=
